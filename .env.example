# ─────────────────────────────────────────────────────────────
# Modalia AI — global site (modalia.ai) — environment variables
# All values are optional for the landing build; sensible defaults
# live in constants/site.ts. Copy to .env.local and fill as needed.
# ─────────────────────────────────────────────────────────────

# Site origins
# Global domain this app is served from (canonical / hreflang base).
NEXT_PUBLIC_SITE_URL=https://modalia.ai
# Korean site origin — used for the cross-domain hreflang (ko) + x-default.
NEXT_PUBLIC_KO_SITE_URL=https://mindthos.com
# Product app — all "Start for free / Log in" CTAs point here.
NEXT_PUBLIC_APP_URL=https://app.mindthos.com
NEXT_PUBLIC_SITE_EMAIL=business@mindfullabs.ai

# Pre-launch mode. While "true" (or unset), every app-bound CTA opens the waitlist
# modal (email capture + demo video) instead of navigating to app.mindthos.com.
# Set to "false" at global launch to restore direct app navigation.
NEXT_PUBLIC_PRELAUNCH=true
# YouTube id for the demo video embedded in the waitlist modal.
NEXT_PUBLIC_DEMO_VIDEO_ID=xAOSEFBhxYk

# Analytics (optional — scripts render only when an ID is present)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
# Google Ads signup-click conversion action (e.g. AW-XXXX/yyyy). Empty = no conversion event.
NEXT_PUBLIC_GOOGLE_ADS_SIGNUP_CONVERSION=

# Social channel overrides (optional — empty = SITE_CONFIG defaults)
NEXT_PUBLIC_INSTAGRAM=
NEXT_PUBLIC_THREADS=
NEXT_PUBLIC_LINKEDIN=
NEXT_PUBLIC_TWITTER=

# ─────────────────────────────────────────────────────────────
# Blog — Supabase (SAME project as the Korean site; reads global_* tables only).
# Required for the blog to build/render. Public anon key (RLS-protected reads).
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://ulrxefpxlsbpjgvpxxor.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Publishing pipeline (server-only — never NEXT_PUBLIC). Used by scripts/publish-global-post.mjs
# and the /api/revalidate + /api/indexnow routes.
SUPABASE_SERVICE_ROLE_KEY=
# Shared secret guarding /api/revalidate and /api/indexnow (sent as ?secret= or x-revalidate-secret).
REVALIDATE_SECRET=
# IndexNow key for modalia.ai (Bing-issued). The matching /<key>.txt is hosted at the
# site root in public/ — the value here MUST equal that filename (minus .txt).
INDEXNOW_KEY=31e475628d034bf08bf981ccc2815e49
